# =============================================================================
# Django
# =============================================================================
DJANGO_SECRET_KEY=troque-em-producao-use-string-longa-e-aleatoria

# Homologação / produção: false
DJANGO_DEBUG=false

# Hosts permitidos (vírgula, sem espaços desnecessários)
DJANGO_ALLOWED_HOSTS=comprasbi.mogidascruzes.sp.gov.br,localhost,127.0.0.1

# HTTPS no browser + Apache em *:80 atrás do balanceador: o vhost define
# X-Forwarded-Proto: https para o Gunicorn (ver deploy/apache-comprasbi.conf).
DJANGO_USE_TLS=true
DJANGO_SECURE_SSL_REDIRECT=false

# false = Django usa o header Host da requisição (evita 400 se o LB manda X-Forwarded-Host inválido)
DJANGO_USE_X_FORWARDED_HOST=false

# Origem real do utilizador (https)
DJANGO_CSRF_TRUSTED_ORIGINS=https://comprasbi.mogidascruzes.sp.gov.br

# Com DJANGO_DEBUG=false: CORS; mesmo host que o CSRF
CORS_ALLOWED_ORIGINS=https://comprasbi.mogidascruzes.sp.gov.br

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_DB=mogi_compras
POSTGRES_USER=mogi_compras_app
POSTGRES_PASSWORD=defina_uma_senha_forte
POSTGRES_HOST=203.0.113.50
POSTGRES_PORT=5432

# =============================================================================
# Shared AI Service (embeddings mxbai-embed-large-v1, 1024 dim)
# =============================================================================
AI_SERVICE_URL=http://192.168.10.50:8004

# =============================================================================
# PNCP (sync)
# =============================================================================
# PNCP_CNPJ_ORGAO=

# =============================================================================
# Frontend (build) — opcional; se vazio, em produção usa mesmo origin + /api
# =============================================================================
# VITE_API_BASE_URL=https://comprasbi.mogidascruzes.sp.gov.br/api
